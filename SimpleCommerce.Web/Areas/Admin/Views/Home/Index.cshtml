@{
    ViewData["Title"] = "Dashboard";
    int totalOrders = ViewBag.TotalOrders ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
    int inProgressCount = ViewBag.InProgressCount ?? 0;
    int deliveredCount = ViewBag.DeliveredCount ?? 0;
}

<div class="row mb-4">
    <div class="col-lg-8">
        <h2 class="mb-2">Admin Dashboard</h2>
        <p class="text-muted mb-0">Welcome to the admin panel. Use the shortcuts below to manage your store.</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-primary">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Total Orders</h6>
                <h3 class="mb-0">@totalOrders</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-warning">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Pending</h6>
                <h3 class="mb-0 text-warning">@pendingCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-info">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">In Progress</h6>
                <h3 class="mb-0 text-info">@inProgressCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Delivered</h6>
                <h3 class="mb-0 text-success">@deliveredCount</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Products</h5>
                <p class="card-text flex-grow-1">View, create, and manage products.</p>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary mt-2">Manage Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Orders</h5>
                <p class="card-text flex-grow-1">View orders and update status (Pending, In Progress, Delivered).</p>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-primary mt-2">Manage Orders</a>
            </div>
        </div>
    </div>
</div>

