@model SimpleCommerce.Contract.ProductDto

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row mb-3">
    <div class="col-12">
        <h2 class="mb-0">Delete Product</h2>
    </div>
</div>

<div class="card shadow-sm border-danger">
    <div class="card-body">
        <p class="text-danger mb-4">Are you sure you want to delete this product? This action cannot be undone.</p>
        <div class="row g-4">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3 text-muted">Description</dt>
                    <dd class="col-sm-9">@(Model.Description ?? "—")</dd>

                    <dt class="col-sm-3 text-muted">Price</dt>
                    <dd class="col-sm-9">@Model.Price.ToString("#,##0.00")</dd>
                </dl>
            </div>
            <div class="col-md-6">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <div class="border rounded bg-white d-flex align-items-center justify-content-center p-2" style="min-height: 120px;">
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="max-height: 140px;" />
                    </div>
                }
            </div>
        </div>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
