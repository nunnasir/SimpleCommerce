@model SimpleCommerce.Contract.ProductDto

@{
    ViewData["Title"] = "Product Details";
}

<div class="row mb-4">
    <div class="col-12">
        <a asp-action="Index" class="btn btn-link ps-0">&laquo; Back to Products</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="border rounded bg-white d-flex align-items-center justify-content-center p-3">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="max-height: 380px;" />
            </div>
        }
        else
        {
            <div class="border rounded bg-light d-flex align-items-center justify-content-center text-muted" style="min-height: 200px;">
                No image available
            </div>
        }
    </div>
    <div class="col-md-6">
        <h2 class="mb-3">@Model.Name</h2>
        <p class="lead mb-3">@Model.Price.ToString("0.00")</p>
        <p class="mb-4">
            @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)
        </p>

        <button type="button" class="btn btn-primary me-2" disabled>Add to Cart</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Products</a>
    </div>
</div>

