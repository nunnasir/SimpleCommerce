@model IEnumerable<SimpleCommerce.Contract.ProductDto>

@{
    ViewData["Title"] = "Products";
}

<div class="row mb-4">
    <div class="col-12 text-center">
        <h1 class="display-5 mb-2">Our Products</h1>
        <p class="text-muted mb-0">Browse our latest items and add them to your cart.</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                {
                    <div class="d-flex align-items-center justify-content-center bg-white" style="height: 200px; overflow: hidden;">
                        <img src="@product.ImageUrl" class="img-fluid" alt="@product.Name"
                             style="max-height: 190px; object-fit: contain;" />
                    </div>
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title mb-3">@product.Name</h5>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <span class="fw-bold">@product.Price.ToString("#,##0.00")</span>
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-secondary btn-sm">Details</a>
                    <form asp-controller="Cart" asp-action="AddToCart" asp-route-id="@product.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
