@model List<SimpleCommerce.Web.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <h2 class="mb-0">Shopping Cart</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Continue Shopping</a>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-3">Your cart is empty.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Browse Products</a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th class="text-end">Price</th>
                    <th class="text-center">Quantity</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="img-thumbnail me-3" style="width: 60px; height: 60px; object-fit: contain;" />
                                }
                                <span>@item.ProductName</span>
                            </div>
                        </td>
                        <td class="text-end">@item.Price.ToString("0.00")</td>
                        <td class="text-center">
                            <div class="d-flex align-items-center justify-content-center gap-1">
                                <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ProductId" />
                                    <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Decrease">−</button>
                                </form>
                                <span class="px-2 fw-bold" style="min-width: 2rem;">@item.Quantity</span>
                                <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ProductId" />
                                    <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Increase">+</button>
                                </form>
                            </div>
                        </td>
                        <td class="text-end fw-bold">@item.LineTotal.ToString("0.00")</td>
                        <td>
                            <form asp-action="Remove" method="post" class="d-inline" onsubmit="return confirm('Remove this item?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ProductId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <span class="fw-bold">Total: @Model.Sum(x => x.LineTotal).ToString("0.00")</span>
            <div>
                <a asp-action="Checkout" class="btn btn-success me-2">Checkout</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Continue Shopping</a>
            </div>
        </div>
    </div>
}
